<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="270"
                android:endColor="#A3211710"
                android:startColor="#C13C2817" />
            <stroke android:width="1dp" android:color="#67512F18" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <solid android:color="#2B0D0804" />
        </shape>
    </item>
</layer-list>
