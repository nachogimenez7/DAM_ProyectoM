<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="270"
                android:endColor="#B1271C11"
                android:startColor="#D45A381B" />
            <stroke android:width="1dp" android:color="#8A6B3418" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#2A0F0904" />
        </shape>
    </item>
</layer-list>
