<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:endColor="#B77A24"
                android:startColor="#F5D777" />
            <stroke
                android:width="4dp"
                android:color="#6A241B" />
        </shape>
    </item>
    <item
        android:bottom="7dp"
        android:left="7dp"
        android:right="7dp"
        android:top="7dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <gradient
                android:angle="270"
                android:endColor="#D7AD5A"
                android:startColor="#F2D99B" />
            <stroke
                android:width="2dp"
                android:color="#D5A632" />
        </shape>
    </item>
</layer-list>
