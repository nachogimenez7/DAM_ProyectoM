<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#F2D694" />
            <stroke
                android:width="3dp"
                android:color="#D5A632" />
        </shape>
    </item>
    <item
        android:bottom="7dp"
        android:left="7dp"
        android:right="7dp"
        android:top="7dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <solid android:color="#E8C87C" />
            <stroke
                android:width="1dp"
                android:color="#6B3D18" />
        </shape>
    </item>
</layer-list>
