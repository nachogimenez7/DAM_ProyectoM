<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <!-- Back button top left -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_dark"
        android:src="@android:drawable/ic_media_previous"
        android:tint="@color/text_secondary"
        android:contentDescription="Volver" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔"
            android:textColor="@color/accent_gold"
            android:textSize="48sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONAR MODO"
            android:textColor="@color/accent_gold"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Cómo querés jugar?"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="48dp" />

        <!-- LOCAL -->
        <Button
            android:id="@+id/btnLocal"
            style="@style/BtnGold"
            android:text="🏠  JUEGO LOCAL" />

        <!-- ONLINE -->
        <Button
            android:id="@+id/btnOnline"
            style="@style/BtnDark"
            android:text="🌐  JUGAR EN LÍNEA" />

        <!-- Description local -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Juego Local: todos los jugadores comparten un mismo dispositivo. Ideal para reuniones presenciales."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="8dp" />

    </LinearLayout>

</RelativeLayout>
