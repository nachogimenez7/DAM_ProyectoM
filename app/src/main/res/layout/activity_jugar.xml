<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_menu" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BB0C0906" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_dark"
        android:contentDescription="Volver"
        android:src="@android:drawable/ic_media_previous"
        android:tint="@color/text_secondary" />

    <TextView
        android:id="@+id/titlePlayMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/grenze"
        android:letterSpacing="0"
        android:text="SELECCIONAR MODO"
        android:textColor="@color/accent_gold"
        android:textSize="23sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/titlePlayMode"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <LinearLayout
            android:id="@+id/cardLocal"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_btn_dark"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imgLocalMode"
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:background="@drawable/placeholder_local"
                android:contentDescription="Imagen de juego local"
                android:scaleType="centerCrop" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:text="JUGAR LOCAL"
                android:textColor="@color/text_primary"
                android:textSize="19sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardOnline"
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="@drawable/bg_btn_dark"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="10dp">

            <ImageView
                android:id="@+id/imgOnlineMode"
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:background="@drawable/placeholder_online"
                android:contentDescription="Imagen de juego online"
                android:scaleType="centerCrop" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:text="JUGAR EN LINEA"
                android:textColor="@color/text_primary"
                android:textSize="19sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>

