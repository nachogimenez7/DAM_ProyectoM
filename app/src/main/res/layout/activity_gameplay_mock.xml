<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gameplayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/mapa_pampa" />

    <LinearLayout
        android:id="@+id/gameplayBody"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:baselineAligned="false"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal">

        <ScrollView
            android:id="@+id/leftPlayersScroll"
            android:layout_width="76dp"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:overScrollMode="ifContentScrolls"
            android:scrollbarStyle="outsideOverlay">

            <LinearLayout
                android:id="@+id/leftPlayersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:gravity="center|center_horizontal"
                android:orientation="vertical"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />
        </ScrollView>

        <FrameLayout
            android:id="@+id/centerColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/topStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_gravity="top"
                android:background="@drawable/bg_translucent_game_panel"
                android:elevation="7dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="6dp">

                    <TextView
                        android:id="@+id/phaseTitle"
                        android:layout_width="78dp"
                        android:layout_height="match_parent"
                        android:ellipsize="end"
                        android:fontFamily="@font/grenze"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="REPARTO"
                        android:textColor="@color/accent_gold"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/phaseSubtitle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/cormorant_garamond"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="Mira tu rol. La noche empieza enseguida."
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/phaseCountdown"
                        android:layout_width="34dp"
                        android:layout_height="30dp"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_btn_dark"
                        android:fontFamily="@font/grenze"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="20"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="invisible" />

                    <FrameLayout
                        android:id="@+id/chatButtonFrame"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="5dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <ImageButton
                            android:id="@+id/btnToggleChat"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_btn_dark"
                            android:contentDescription="Abrir chat"
                            android:padding="7dp"
                            android:src="@drawable/ic_chat_speaking"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/chatUnreadBadge"
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="-2dp"
                            android:layout_marginEnd="-2dp"
                            android:background="@drawable/bg_chat_badge"
                            android:gravity="center"
                            android:maxLines="1"
                            android:text="1"
                            android:textColor="@android:color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_btn_dark"
                        android:contentDescription="Opciones"
                        android:padding="7dp"
                        android:src="@drawable/ic_settings_gear"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/phaseProgressTrack"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="@color/divider">

                    <View
                        android:id="@+id/phaseProgressFill"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/accent_gold" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/eventLogPanel"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_gravity="top"
                android:layout_marginTop="52dp"
                android:background="@drawable/bg_translucent_game_panel"
                android:elevation="6dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/eventLogHeader"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="5dp">

                    <View
                        android:id="@+id/eventLogColorBar"
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/accent_green" />

                    <TextView
                        android:id="@+id/eventLogTitle"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:ellipsize="end"
                        android:fontFamily="@font/grenze"
                        android:maxLines="1"
                        android:text="EVENTOS"
                        android:textColor="@color/accent_gold"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/eventLogSummary"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="3dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:fontFamily="@font/cormorant_garamond"
                        android:gravity="center_vertical"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="La partida esta por comenzar."
                        android:textColor="@color/text_secondary"
                        android:textSize="9.5sp" />

                    <Button
                        android:id="@+id/btnToggleEventLog"
                        style="@style/BtnDark"
                        android:layout_width="26dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:text="&#9660;"
                        android:textSize="9sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/eventLogContent"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/eventLogBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitXY"
                        android:src="@drawable/log_gaucho" />

                    <ScrollView
                        android:id="@+id/eventLogScroll"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fillViewport="false"
                        android:overScrollMode="ifContentScrolls"
                        android:scrollbarStyle="outsideOverlay">

                        <LinearLayout
                            android:id="@+id/eventLogContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingHorizontal="6dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="4dp" />
                    </ScrollView>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottomPlayerPanel"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_hud_parchment"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="7dp"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:id="@+id/roleCard"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_role_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="3dp">

                    <ImageView
                        android:id="@+id/roleImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:background="@android:color/transparent"
                        android:contentDescription="Carta de rol"
                        android:scaleType="fitCenter" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="9dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/currentPlayerName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/grenze"
                        android:maxLines="1"
                        android:text="Nacho"
                        android:textColor="@color/accent_gold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/roleName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/grenze"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="CARTA OCULTA"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/currentPlayerHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/cormorant_garamond"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="Tu carta esta oculta."
                        android:textColor="@color/text_muted"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="202dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnRevealCard"
                        style="@style/BtnGold"
                        android:layout_width="78dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="0dp"
                        android:text="REVELAR"
                        android:textSize="8sp" />

                    <Button
                        android:id="@+id/btnVote"
                        style="@style/BtnDark"
                        android:layout_width="118dp"
                        android:layout_height="38dp"
                        android:layout_marginBottom="0dp"
                        android:text="ELEGIR OBJETIVO"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chatPanel"
                android:layout_width="216dp"
                android:layout_height="match_parent"
                android:layout_gravity="top|end"
                android:layout_marginTop="86dp"
                android:layout_marginBottom="68dp"
                android:background="@drawable/bg_chat_panel"
                android:elevation="10dp"
                android:orientation="vertical"
                android:padding="9dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:fontFamily="@font/grenze"
                        android:gravity="center_vertical"
                        android:text="CHAT"
                        android:textColor="@color/accent_gold"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnCloseChat"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_btn_dark"
                        android:contentDescription="Cerrar chat"
                        android:padding="7dp"
                        android:src="@drawable/ic_close"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/chatMessagesScroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:layout_weight="1"
                    android:fillViewport="true"
                    android:overScrollMode="ifContentScrolls">

                    <TextView
                        android:id="@+id/chatMessages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:lineSpacingExtra="1dp"
                        android:text="Todavia no hay mensajes."
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </ScrollView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/chatInput"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chat_input"
                        android:hint="Escribir..."
                        android:maxLines="1"
                        android:paddingHorizontal="8dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_muted"
                        android:textSize="10sp" />

                    <Button
                        android:id="@+id/btnSendChat"
                        style="@style/BtnGold"
                        android:layout_width="54dp"
                        android:layout_height="32dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="0dp"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:padding="0dp"
                        android:text="ENVIAR"
                        android:textSize="7sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/rightColumn"
            android:layout_width="76dp"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/rightPlayersScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbarStyle="outsideOverlay">

                <LinearLayout
                    android:id="@+id/rightPlayersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center|center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/deathRevealOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B8000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <View
            android:id="@+id/deathRevealFlash"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="#A0A01818" />

        <LinearLayout
            android:id="@+id/deathRevealContent"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_translucent_game_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="AL AMANECER..."
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/deathRevealCardStage"
                android:layout_width="150dp"
                android:layout_height="154dp"
                android:layout_marginTop="5dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <FrameLayout
                    android:id="@+id/deathRevealCard"
                    android:layout_width="94dp"
                    android:layout_height="124dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_role_card"
                    android:padding="4dp">

                    <ImageView
                        android:id="@+id/deathRevealCardBack"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/card_back_traidores" />

                    <ImageView
                        android:id="@+id/deathRevealCardFront"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Rol del jugador eliminado"
                        android:scaleType="fitCenter"
                        android:visibility="invisible" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/deathRevealBloodLeft"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="start|center_vertical"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:rotation="-18"
                    android:src="@drawable/death_blood_splatter" />

                <ImageView
                    android:id="@+id/deathRevealBloodRight"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="end|bottom"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:rotation="24"
                    android:src="@drawable/death_blood_splatter" />
            </FrameLayout>

            <TextView
                android:id="@+id/deathRevealPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="MARTINA"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deathRevealRoleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="ALDEANA"
                android:textColor="@color/accent_gold"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Murió durante la noche"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/silenceRevealOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B8000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/silenceRevealContent"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_translucent_game_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="UNA VOZ FUE SILENCIADA"
                android:textColor="@color/accent_gold"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="174dp"
                android:layout_height="170dp"
                android:layout_marginTop="4dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <FrameLayout
                    android:id="@+id/silenceRevealCard"
                    android:layout_width="94dp"
                    android:layout_height="124dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_role_card"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/card_back_traidores" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/silenceRevealCageLeft"
                    android:layout_width="54dp"
                    android:layout_height="150dp"
                    android:layout_gravity="start|center_vertical"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:src="@drawable/silence_cage_side" />

                <ImageView
                    android:id="@+id/silenceRevealCageRight"
                    android:layout_width="54dp"
                    android:layout_height="150dp"
                    android:layout_gravity="end|center_vertical"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:scaleX="-1"
                    android:src="@drawable/silence_cage_side" />

                <ImageView
                    android:id="@+id/silenceRevealCageDoor"
                    android:layout_width="104dp"
                    android:layout_height="144dp"
                    android:layout_gravity="center"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:src="@drawable/silence_cage_door" />

                <ImageView
                    android:id="@+id/silenceRevealCageLock"
                    android:layout_width="30dp"
                    android:layout_height="38dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:src="@drawable/silence_cage_lock" />
            </FrameLayout>

            <TextView
                android:id="@+id/silenceRevealPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="MARTINA"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/cormorant_garamond"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="No puede hablar ni votar durante el dia"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/rolePreviewOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/rolePreviewContent"
            android:layout_width="270dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_translucent_game_panel"
            android:clickable="true"
            android:focusable="true"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="4dp">

                <ImageView
                    android:id="@+id/rolePreviewImage"
                    android:layout_width="180dp"
                    android:layout_height="220dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Carta de rol ampliada"
                    android:scaleType="fitCenter" />

                <TextView
                    android:id="@+id/rolePreviewName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="ROL"
                    android:textColor="@color/accent_gold"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCloseRolePreview"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_btn_dark"
                android:contentDescription="Cerrar carta ampliada"
                android:padding="8dp"
                android:src="@drawable/ic_close"
                app:tint="@color/text_secondary" />
        </FrameLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/traitorRevealOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/traitorRevealContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_translucent_game_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="18dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:text="TUS COMPAÑEROS TRAIDORES"
                android:textColor="@color/accent_gold"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/traitorRevealCards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/cormorant_garamond"
                android:text="Toca para continuar"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/dayNightTransitionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/transitionFromBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/transitionToBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:contentDescription="@null"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/transitionShade"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#44090B10" />

        <ImageView
            android:id="@+id/transitionSun"
            android:layout_width="116dp"
            android:layout_height="116dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/transition_sun" />

        <ImageView
            android:id="@+id/transitionMoon"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/transition_moon" />

        <TextView
            android:id="@+id/transitionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:alpha="0"
            android:fontFamily="@font/grenze"
            android:gravity="center"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="8"
            android:text="NOCHE 1"
            android:textColor="@color/accent_gold"
            android:textSize="34sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/winnerRevealOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B8000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/winnerRevealPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginHorizontal="36dp"
            android:layout_marginVertical="16dp">

            <ImageView
                android:id="@+id/winnerRevealBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY"
                android:src="@drawable/log_gaucho" />

            <View
                android:id="@+id/winnerRevealShine"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="#55FFF1BD" />

            <LinearLayout
                android:id="@+id/winnerRevealContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="42dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/winnerRevealTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:shadowColor="#66FFF0B0"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="5"
                    android:text="EL PUEBLO HA GANADO"
                    android:textColor="#3A2413"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/winnerRevealPersonalResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="VICTORIA"
                    android:textColor="#765019"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/winnerRevealCards"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="4dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/btnWinnerReturnLobby"
                    style="@style/BtnDark"
                    android:layout_width="154dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="0dp"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"
                    android:text="VOLVER A SALA"
                    android:textSize="11sp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

</RelativeLayout>
