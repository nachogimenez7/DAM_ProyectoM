<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/mapa_pampa" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#730C0906" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:background="@drawable/bg_btn_dark"
        android:contentDescription="Volver"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous"
        android:tint="@color/text_secondary" />

    <LinearLayout
        android:id="@+id/topStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="62dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="62dp"
        android:background="@drawable/bg_game_panel"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/phaseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:letterSpacing="0.02"
                android:text="NOCHE 1"
                android:textColor="@color/accent_gold"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/phaseSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/cormorant_garamond"
                android:maxLines="1"
                android:text="El Detective puede investigar a un jugador."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnNextPhase"
            style="@style/BtnDark"
            android:layout_width="150dp"
            android:layout_height="44dp"
            android:layout_marginBottom="0dp"
            android:text="SIGUIENTE" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/leftPlayers"
        android:layout_width="84dp"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_below="@id/topStatus"
        android:layout_above="@id/bottomPanel"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <include
            android:id="@+id/playerL1"
            layout="@layout/item_mock_player_left" />

        <include
            android:id="@+id/playerL2"
            layout="@layout/item_mock_player_left" />

        <include
            android:id="@+id/playerL3"
            layout="@layout/item_mock_player_left" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rightPlayers"
        android:layout_width="84dp"
        android:layout_height="match_parent"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/topStatus"
        android:layout_above="@id/bottomPanel"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="10dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <include
            android:id="@+id/playerR1"
            layout="@layout/item_mock_player_right" />

        <include
            android:id="@+id/playerR2"
            layout="@layout/item_mock_player_right" />

        <include
            android:id="@+id/playerR3"
            layout="@layout/item_mock_player_right" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/centerPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/topStatus"
        android:layout_above="@id/bottomPanel"
        android:layout_marginStart="104dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="104dp"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/actionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_game_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/actionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:text="OBJETIVO"
                android:textColor="@color/accent_gold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/targetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cormorant_garamond"
                android:text="Selecciona un jugador"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="138dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="112dp"
        android:layout_marginEnd="112dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_game_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/roleCard"
            android:layout_width="84dp"
            android:layout_height="118dp"
            android:background="@drawable/bg_role_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="5dp">

            <ImageView
                android:id="@+id/roleImage"
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:background="@drawable/bg_card_back"
                android:contentDescription="Carta de rol"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/roleName"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="@font/grenze"
                android:gravity="center"
                android:text="OCULTO"
                android:textColor="@color/bg_dark"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/currentPlayerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:text="Nacho"
                android:textColor="@color/accent_gold"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/currentPlayerHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="@font/cormorant_garamond"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:text="Tu carta esta oculta. Revelala solo cuando una regla lo permita."
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="156dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnRevealCard"
                style="@style/BtnGold"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="REVELAR" />

            <Button
                android:id="@+id/btnVote"
                style="@style/BtnDark"
                android:layout_height="48dp"
                android:layout_marginBottom="0dp"
                android:text="VOTAR" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
