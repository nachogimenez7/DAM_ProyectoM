<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:background="@drawable/bg_btn_dark"
        android:contentDescription="Volver"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/text_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/grenze"
            android:text="ASIGNANDO ROLES..."
            android:textColor="@color/accent_gold"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/cormorant_garamond"
            android:text="Nadie debe mirar la carta de otro jugador."
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>
</RelativeLayout>
