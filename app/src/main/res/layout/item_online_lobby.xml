<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_player_chip"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingEnd="8dp">

    <TextView
        android:id="@+id/lobbyRegion"
        android:layout_width="42dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="🇦🇷"
        android:textSize="24sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lobbyName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/grenze"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lobbyMap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="@font/cormorant_garamond"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/lobbyPlayers"
        android:layout_width="62dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/grenze"
        android:gravity="center"
        android:textColor="@color/accent_gold"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lobbyStatus"
        android:layout_width="94dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cormorant_garamond"
        android:gravity="center"
        android:maxLines="2"
        android:textColor="@color/accent_green"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnEnterLobby"
        android:layout_width="104dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_btn_gold"
        android:fontFamily="@font/grenze"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="ENTRAR"
        android:textColor="@color/bg_dark"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>
