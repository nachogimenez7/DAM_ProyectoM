<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Background dim overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_dark"
        android:src="@android:drawable/ic_media_previous"
        android:tint="@color/text_secondary"
        android:contentDescription="Volver" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnBack"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️"
                android:textSize="40sp"
                android:layout_gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="OPCIONES"
                android:textColor="@color/accent_gold"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:letterSpacing="0.15"
                android:layout_marginBottom="24dp" />

            <!-- CONFIGURACIÓN DE AUDIO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔊 Sonido y Audio"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_btn_dark"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Efectos de Sonido / Música"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- CONFIGURACIÓN DE IDIOMA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌐 Idioma del Juego"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_btn_dark"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seleccionar Idioma"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:layout_marginStart="4dp" />

                <Spinner
                    android:id="@+id/spinnerLanguage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/accent_gold"
                    android:spinnerMode="dropdown" />
            </LinearLayout>

            <!-- REGISTRO / INICIAR SESIÓN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Cuenta de Jugador"
                android:textColor="@color/accent_gold"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_btn_dark"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar Sesión / Registrarse"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_dark"
                    android:hint="Nombre de usuario"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:inputType="text"
                    android:maxLines="1"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_dark"
                    android:hint="Contraseña"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnLogin"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_btn_gold"
                        android:text="INGRESAR"
                        android:textColor="@color/bg_dark"
                        android:textStyle="bold"
                        android:fontFamily="serif" />

                    <Button
                        android:id="@+id/btnRegister"
                        style="?android:attr/buttonStyleSmall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_btn_dark"
                        android:text="REGISTRARSE"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:fontFamily="serif" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
