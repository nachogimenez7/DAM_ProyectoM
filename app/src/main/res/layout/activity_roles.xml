<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_menu" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_dark"
        android:contentDescription="Volver"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/text_secondary" />

    <TextView
        android:id="@+id/titleRoles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/grenze"
        android:letterSpacing="0.02"
        android:text="LOS ROLES"
        android:textColor="@color/accent_gold"
        android:textSize="24sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:id="@+id/mapScroller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/titleRoles"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/mapMedieval"
                android:layout_width="150dp"
                android:layout_height="132dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_btn_dark"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:contentDescription="Feudo de Hierro"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mapa_medieval" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Feudo"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mapGreece"
                android:layout_width="150dp"
                android:layout_height="132dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_btn_dark"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:contentDescription="Antigua Grecia"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mapa_grecia" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Grecia"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mapPampa"
                android:layout_width="150dp"
                android:layout_height="132dp"
                android:background="@drawable/bg_btn_dark"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:contentDescription="Pueblo del Interior"
                    android:scaleType="centerCrop"
                    android:src="@drawable/mapa_pampa" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Interior"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/selectedMapTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/mapScroller"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/grenze"
        android:gravity="center"
        android:letterSpacing="0.02"
        android:textColor="@color/accent_gold"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/selectedMapContext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/selectedMapTitle"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/cormorant_garamond"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rolesRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/selectedMapContext"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp" />

</RelativeLayout>


