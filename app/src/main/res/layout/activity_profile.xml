<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/fondo_menu" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#52000000" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_btn_dark"
        android:contentDescription="Volver"
        android:padding="10dp"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/text_secondary" />

    <TextView
        android:id="@+id/profileTitle"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_alignTop="@id/btnBack"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/grenze"
        android:gravity="center"
        android:text="PERFIL"
        android:textColor="@color/accent_gold"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnBack"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingTop="4dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="14dp"
            android:paddingEnd="18dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="174dp">

                <View
                    android:id="@+id/profileBanner"
                    android:layout_width="match_parent"
                    android:layout_height="112dp"
                    android:background="@drawable/profile_banner_pampa"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageButton
                    android:id="@+id/editBanner"
                    style="@style/ProfileEditIcon"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp" />

                <FrameLayout
                    android:id="@+id/profileAvatarFrame"
                    android:layout_width="116dp"
                    android:layout_height="116dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:background="@drawable/bg_profile_avatar_frame"
                    android:elevation="6dp"
                    android:padding="5dp">

                    <ImageView
                        android:id="@+id/profileAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_avatar_clip"
                        android:clickable="true"
                        android:clipToOutline="true"
                        android:contentDescription="Ampliar foto de perfil"
                        android:focusable="true"
                        android:outlineProvider="background"
                        android:scaleType="matrix"
                        android:src="@drawable/rol_aldeano_gaucho" />

                    <ImageButton
                        android:id="@+id/editAvatar"
                        style="@style/ProfileEditIcon"
                        android:layout_gravity="bottom|end" />
                </FrameLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/profileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingHorizontal="38dp"
                    android:text="Jugador"
                    android:textColor="@color/text_primary"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/editName"
                    style="@style/ProfileEditIcon"
                    android:layout_gravity="center_vertical|end" />
            </FrameLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/profilePublicId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:paddingHorizontal="38dp"
                    android:text="#trd-a7k4p2"
                    android:textColor="@color/accent_gold"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/editPublicId"
                    style="@style/ProfileEditIcon"
                    android:layout_gravity="center_vertical|end" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/profileBioBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_profile_stat">

                <TextView
                    android:id="@+id/profileBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:paddingStart="44dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="44dp"
                    android:paddingBottom="12dp"
                    android:text="&quot;No fui yo. Esta vez.&quot;"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:textStyle="italic" />

                <ImageButton
                    android:id="@+id/editBio"
                    style="@style/ProfileEditIcon"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/grenze"
                android:text="ESTADISTICAS"
                android:textColor="@color/accent_gold"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_stat"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/grenze"
                        android:text="24"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:text="Partidas"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_stat"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/grenze"
                        android:text="14"
                        android:textColor="@color/accent_green"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:text="Victorias"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_stat"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/grenze"
                        android:text="58%"
                        android:textColor="@color/accent_gold"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:text="Victorias"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/favoriteRoleCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_profile_stat"
                android:clickable="true"
                android:contentDescription="Ver informacion del rol Detective"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/favoriteRoleImage"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="Rol favorito"
                    android:scaleType="centerCrop"
                    android:src="@drawable/rol_detective_gaucho" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:text="ROL FAVORITO"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/favoriteRoleName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/grenze"
                        android:text="Detective"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/editFavoriteRole"
                    style="@style/ProfileEditIcon" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/grenze"
                    android:gravity="center_vertical"
                    android:text="LOGROS DESTACADOS"
                    android:textColor="@color/accent_gold"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/editAchievements"
                    style="@style/ProfileEditIcon"
                    android:layout_gravity="center_vertical|end" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/achievementsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/achievementOne"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_badge"
                    android:clickable="true"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Engano"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/achievementTwo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_badge"
                    android:clickable="true"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Sobrevivir"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/achievementThree"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_profile_badge"
                    android:clickable="true"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:minHeight="48dp"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Ojo experto"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:autoSizeMaxTextSize="13sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />
            </LinearLayout>

            <Button
                android:id="@+id/btnEditProfile"
                style="@style/BtnGold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="0dp"
                android:text="EDITAR PERFIL" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
