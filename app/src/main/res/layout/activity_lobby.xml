<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/lobbyMapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/mapa_pampa" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:background="@drawable/bg_btn_dark_ripple"
        android:contentDescription="Volver"
        android:padding="8dp"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/text_secondary" />

    <LinearLayout
        android:id="@+id/lobbyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="62dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="62dp"
        android:background="@drawable/bg_game_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lobbyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:text="LOBBY LOCAL"
                android:textColor="@color/accent_gold"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/playerCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cormorant_garamond"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/headerLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/grenze"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/mapName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/cormorant_garamond"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/lobbyBody"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/lobbyHeader"
        android:layout_marginStart="62dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="62dp"
        android:layout_marginBottom="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_game_panel"
            android:fillViewport="true"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/playersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <ScrollView
            android:layout_width="240dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_game_panel"
            android:fillViewport="true"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/lobbyModeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/grenze"
                    android:gravity="center"
                    android:text="MAPA"
                    android:textColor="@color/accent_gold"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/mapPampa"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="Mapa Pampa"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="2dp"
                        android:scaleType="centerCrop" />

                    <ImageView
                        android:id="@+id/mapGrecia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="Mapa Grecia"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="2dp"
                        android:scaleType="centerCrop" />

                    <ImageView
                        android:id="@+id/mapMedieval"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="Mapa Medieval"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:padding="2dp"
                        android:scaleType="centerCrop" />
                </LinearLayout>

                <TextView
                    android:id="@+id/mapDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="@font/cormorant_garamond"
                    android:gravity="center"
                    android:lineSpacingExtra="1dp"
                    android:text="Usa el perfil o la X de cada participante. Inicia con cinco o mas jugadores."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <LinearLayout
                    android:id="@+id/debugRoleSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/grenze"
                        android:gravity="center"
                        android:text="PRUEBA: ROL HUMANO"
                        android:textColor="@color/accent_gold"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnDebugRole"
                        style="@style/BtnDark"
                        android:layout_height="34dp"
                        android:layout_marginBottom="0dp"
                        android:background="@drawable/bg_btn_dark_ripple"
                        android:text="ROL: AZAR"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:fontFamily="@font/grenze"
                    android:letterSpacing="0.08"
                    android:text="CONFIGURACION"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTimingOptions"
                    style="@style/BtnDark"
                    android:layout_height="38dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_btn_dark_ripple"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="TIEMPOS"
                    android:textSize="11sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeMinTextSize="8sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <Button
                    android:id="@+id/btnAdvancedOptions"
                    style="@style/BtnDark"
                    android:layout_height="38dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_btn_dark_ripple"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="OPCIONES AVANZADAS"
                    android:textSize="11sp"
                    app:autoSizeMaxTextSize="11sp"
                    app:autoSizeMinTextSize="9sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="6dp"
                    android:alpha="0.25"
                    android:background="@color/text_secondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:fontFamily="@font/grenze"
                    android:letterSpacing="0.08"
                    android:text="JUGADORES"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginBottom="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAddPlayer"
                        style="@style/BtnDark"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="4dp"
                        android:layout_marginBottom="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_dark_ripple"
                        android:text="AGREGAR"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnRemovePlayer"
                        style="@style/BtnDark"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_dark_ripple"
                        android:text="QUITAR"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnStartGame"
                    style="@style/BtnGold"
                    android:layout_height="46dp"
                    android:layout_marginBottom="0dp"
                    android:background="@drawable/bg_btn_gold_ripple"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="INICIAR"
                    app:autoSizeMaxTextSize="15sp"
                    app:autoSizeMinTextSize="9sp"
                    app:autoSizeStepGranularity="1sp"
                    app:autoSizeTextType="uniform" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</RelativeLayout>
