<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="@drawable/bg_btn_dark"
        android:orientation="vertical"
        android:padding="14dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/detailRoleName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginEnd="44dp"
                android:fontFamily="@font/grenze"
                android:letterSpacing="0.02"
                android:textColor="@color/accent_gold"
                android:textSize="21sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseRoleDetail"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_btn_dark"
                android:contentDescription="Cerrar"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/text_secondary" />
        </RelativeLayout>

        <TextView
            android:id="@+id/detailRoleTeam"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/grenze"
            android:letterSpacing="0.04"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/detailRoleImage"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:adjustViewBounds="true"
            android:contentDescription="Imagen del rol"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/detailRoleFantasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/cormorant_garamond"
            android:lineSpacingExtra="1dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/detailGameplayTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/grenze"
            android:letterSpacing="0.02"
            android:text="EN PARTIDA"
            android:textColor="@color/accent_gold"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailRoleGameplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/cormorant_garamond"
            android:lineSpacingExtra="1dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
