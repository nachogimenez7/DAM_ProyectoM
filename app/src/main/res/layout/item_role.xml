<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_btn_dark"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:gravity="top">

    <ImageView
        android:id="@+id/roleImage"
        android:layout_width="92dp"
        android:layout_height="122dp"
        android:scaleType="centerCrop"
        android:contentDescription="Rol"
        android:layout_marginEnd="16dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/roleName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/roleMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_gold"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/roleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/roleStory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:lineSpacingExtra="3dp" />

        <TextView
            android:id="@+id/roleFunctionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FUNCIÓN"
            android:textColor="@color/accent_gold"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/roleFunction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>
</LinearLayout>
