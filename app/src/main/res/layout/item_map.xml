<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_btn_dark"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:id="@+id/mapImage"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:contentDescription="Mapa"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/mapName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/rye"
        android:letterSpacing="0.02"
        android:textColor="@color/accent_gold"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mapEra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/rye"
        android:letterSpacing="0.04"
        android:textColor="@color/text_muted"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mapDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/cormorant_garamond"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/mapRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/rye"
        android:letterSpacing="0.03"
        android:textColor="@color/accent_green"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>


